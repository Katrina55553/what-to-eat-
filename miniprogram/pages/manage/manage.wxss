/* ============ 菜品管理页 ============ */
.manage {
  height: 100vh;
  height: 100dvh;
  display: flex;
  flex-direction: column;
  padding: 100rpx 24rpx 24rpx;
}

.manage__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(44, 24, 16, 0.05);
  margin-bottom: 28rpx;
  flex-shrink: 0;
}

.manage__title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: 6rpx;
}

.manage__actions {
  display: flex;
  gap: 12rpx;
}

.manage__reset,
.manage__clear {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 12rpx 24rpx;
  border: 2rpx solid rgba(44, 24, 16, 0.12);
  background: transparent;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: var(--ink-soft);
  border-radius: 100rpx;
  line-height: 1.4;
  margin: 0;
}

.manage__reset::after,
.manage__clear::after {
  border: none;
}

.manage__clear {
  color: var(--terracotta);
  border-color: rgba(201, 64, 61, 0.25);
}

/* 添加表单 */
.add-form {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
  flex-shrink: 0;
}

.add-form__input {
  flex: 1;
  height: 84rpx;
  line-height: 44rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid rgba(44, 24, 16, 0.1);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  background: var(--paper);
  color: #2c1810;
  caret-color: var(--terracotta);
}

.add-form__input::placeholder {
  color: #9a8770;
}

.add-form__btn {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 20rpx 36rpx;
  border: none;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, var(--terracotta) 0%, var(--terracotta-deep) 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  line-height: 1.4;
  margin: 0;
}

.add-form__btn::after {
  border: none;
}

/* 搜索栏 */
.dish-search {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.dish-search__input {
  height: 76rpx;
  line-height: 40rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid rgba(44, 24, 16, 0.1);
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  background: var(--paper);
  color: #2c1810;
  caret-color: var(--terracotta);
}

.dish-search__input::placeholder {
  color: #9a8770;
}

.dish-search__filters {
  display: flex;
  gap: 12rpx;
}

.dish-search__filter {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 12rpx 24rpx;
  border: 2rpx solid rgba(44, 24, 16, 0.12);
  border-radius: 100rpx;
  background: var(--paper-deep);
  color: var(--ink-soft);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  line-height: 1.4;
  margin: 0;
}

.dish-search__filter::after {
  border: none;
}

.dish-search__filter--active {
  background: var(--terracotta);
  border-color: var(--terracotta);
  color: #fff;
}

.dish-search__filter--blacklist.dish-search__filter--active {
  background: var(--amber-deep);
  border-color: var(--amber-deep);
}

/* 计数 */
.dish-list__count {
  font-size: 22rpx;
  color: var(--ink-soft);
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx dashed rgba(44, 24, 16, 0.1);
  letter-spacing: 2rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 菜品列表 */
.dish-list {
  flex: 1;
  overflow: hidden;
}

.dish-list__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
  background: rgba(253, 248, 236, 0.5);
  border: 1rpx solid rgba(44, 24, 16, 0.05);
  gap: 16rpx;
}

.dish-list__item--blacklisted {
  opacity: 0.55;
  background: rgba(245, 199, 126, 0.12);
  border-color: rgba(214, 138, 60, 0.2);
}

.dish-list__item--editing {
  background: #fff !important;
  border-color: var(--terracotta) !important;
  box-shadow: 0 0 0 4rpx rgba(201, 64, 61, 0.1);
  opacity: 1 !important;
}

.dish-list__item--highlighted {
  animation: highlight-pulse 1s ease 2;
  border-color: var(--amber) !important;
}

@keyframes highlight-pulse {
  0%, 100% { box-shadow: none; }
  50% { box-shadow: 0 0 0 6rpx rgba(245, 199, 126, 0.5); }
}

.dish-list__info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.dish-list__name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 2rpx;
}

.dish-list__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  align-items: center;
}

.dish-list__tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.dish-list__tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  background: rgba(95, 122, 111, 0.1);
  border-radius: 8rpx;
  color: var(--sage);
  font-weight: 600;
  letter-spacing: 1rpx;
  border: 1rpx solid rgba(95, 122, 111, 0.08);
}

.dish-list__scenes {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  background: rgba(245, 199, 126, 0.25);
  border-radius: 8rpx;
  color: var(--ochre);
  font-weight: 600;
  letter-spacing: 1rpx;
  border: 1rpx solid rgba(245, 199, 126, 0.2);
}

.dish-list__weight {
  font-size: 20rpx;
  color: var(--ink-faint);
  padding: 6rpx 14rpx;
  background: rgba(44, 24, 16, 0.04);
  border-radius: 8rpx;
  white-space: nowrap;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.dish-list__last-eaten {
  font-size: 20rpx;
  color: var(--terracotta);
  padding: 6rpx 14rpx;
  background: rgba(201, 64, 61, 0.08);
  border-radius: 8rpx;
  white-space: nowrap;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.dish-list__actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.dish-list__action-btn {
  width: 56rpx !important;
  height: 56rpx !important;
  min-width: auto !important;
  display: inline-flex !important;
  border: none;
  background: rgba(44, 24, 16, 0.05);
  border-radius: 12rpx;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--ink-soft);
  padding: 0;
  margin: 0;
  line-height: 1;
}

.dish-list__action-btn::after {
  border: none;
}

.dish-list__blacklist--active {
  background: rgba(245, 199, 126, 0.35);
  color: var(--ochre);
}

.dish-list__delete {
  color: var(--terracotta);
}

/* 编辑表单 */
.dish-edit-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

.dish-edit-form__row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.dish-edit-form__label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--ink-soft);
  letter-spacing: 2rpx;
  white-space: nowrap;
  min-width: 64rpx;
}

.dish-edit-form__input {
  flex: 1;
  height: 68rpx;
  line-height: 36rpx;
  padding: 12rpx 20rpx;
  border: 2rpx solid rgba(44, 24, 16, 0.12);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--ink);
  background: rgba(253, 248, 236, 0.6);
}

.dish-edit-form__input--weight {
  flex: none;
  width: 120rpx;
}

.dish-edit-form__scenes {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.dish-edit-form__scene-chip {
  padding: 8rpx 20rpx;
  border: 2rpx solid rgba(44, 24, 16, 0.12);
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(253, 248, 236, 0.5);
  color: var(--ink-soft);
}

.dish-edit-form__scene-chip--active {
  background: var(--terracotta);
  border-color: var(--terracotta);
  color: #fff;
}

.dish-edit-form__actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.dish-edit-form__btn {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 12rpx 28rpx;
  border: none;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  line-height: 1.4;
  margin: 0;
}

.dish-edit-form__btn::after {
  border: none;
}

.dish-edit-form__btn--save {
  background: var(--terracotta);
  color: #fff;
}

.dish-edit-form__btn--cancel {
  background: rgba(44, 24, 16, 0.06);
  color: var(--ink-soft);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 24rpx 60rpx;
  color: var(--ink-soft);
}

.empty-state__icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
  display: inline-block;
}

.empty-state__text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--ink-faint);
  letter-spacing: 2rpx;
}
