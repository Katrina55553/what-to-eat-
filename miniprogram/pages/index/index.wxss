/* ============ 首页布局 ============ */
.app {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100vh;
  height: 100dvh;
  margin: 0 auto;
  padding: 16rpx 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.bg-decoration__item {
  position: absolute;
  color: var(--ink);
  opacity: 0.07;
  animation: float-bg ease-in-out infinite;
}

@keyframes float-bg {
  0% { transform: translateY(110vh) rotate(-10deg); opacity: 0; }
  20% { opacity: 0.08; }
  80% { opacity: 0.08; }
  100% { transform: translateY(-120rpx) rotate(15deg); opacity: 0; }
}

/* 主卡片 */
.main-card {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: linear-gradient(180deg, #fdf8ec 0%, #f8efdb 100%);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(44, 24, 16, 0.08);
  box-shadow: 0 16rpx 48rpx rgba(44, 24, 16, 0.14), 0 32rpx 80rpx rgba(44, 24, 16, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
  padding: 24rpx 28rpx 20rpx;
  position: relative;
}

.main-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--terracotta) 0%, var(--terracotta-light) 25%, var(--amber) 50%, var(--terracotta-light) 75%, var(--terracotta) 100%);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
}

/* 头部 */
.header {
  text-align: center;
  padding: 8rpx 0 16rpx;
  flex-shrink: 0;
}

.header__logo {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 6rpx;
  display: inline-block;
  animation: float 3.5s ease-in-out infinite;
}

.header__title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 6rpx;
  line-height: 1.2;
  color: var(--ink);
  margin-bottom: 6rpx;
}

.header__subtitle {
  display: block;
  font-size: 18rpx;
  color: var(--ink-faint);
  letter-spacing: 4rpx;
  font-weight: 500;
}

/* 徽章 */
.badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 0 auto 16rpx;
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, rgba(245, 199, 126, 0.25), rgba(201, 64, 61, 0.12));
  border: 2rpx solid rgba(201, 64, 61, 0.25);
  border-radius: 100rpx;
  box-shadow: 0 4rpx 14rpx rgba(201, 64, 61, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
  width: fit-content;
}

.badge__icon {
  font-size: 24rpx;
  line-height: 1;
}

.badge__text {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--terracotta);
  white-space: nowrap;
}

/* 场景栏 */
.scene-bar {
  display: flex;
  gap: 12rpx;
  padding: 0 0 16rpx;
  flex-wrap: wrap;
  justify-content: center;
  flex-shrink: 0;
}

.scene-bar__btn {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 14rpx 28rpx;
  border: 2rpx solid rgba(44, 24, 16, 0.1);
  border-radius: 100rpx;
  background: rgba(253, 248, 236, 0.6);
  color: var(--ink-soft);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  line-height: 1.4;
  align-items: center;
  gap: 8rpx;
  margin: 0;
}

.scene-bar__btn::after {
  border: none;
}

.scene-bar__btn--active {
  background: linear-gradient(135deg, var(--terracotta) 0%, var(--terracotta-deep) 100%);
  border-color: var(--terracotta-deep);
  color: #fff;
}

.scene-bar__icon {
  font-size: 24rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 0 0 20rpx;
  flex-wrap: wrap;
  justify-content: center;
  flex-shrink: 0;
}

.filter-bar__chip {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 12rpx 24rpx;
  border: 2rpx solid rgba(95, 122, 111, 0.18);
  border-radius: 100rpx;
  background: rgba(95, 122, 111, 0.05);
  color: var(--sage);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  margin: 0;
}

.filter-bar__chip::after {
  border: none;
}

.filter-bar__chip--active {
  background: linear-gradient(135deg, var(--sage) 0%, var(--sage-deep) 100%);
  border-color: var(--sage-deep);
  color: #fff;
}

/* 转盘区域 */
.wheel-section {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 0;
  padding: 20rpx 0;
}

.wheel-section::before {
  content: '';
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(245, 199, 126, 0.45) 0%, rgba(201, 64, 61, 0.08) 40%, transparent 65%);
  border-radius: 50%;
  animation: warm-pulse 4s ease-in-out infinite;
}

@keyframes warm-pulse {
  0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.85; transform: translate(-50%, -50%) scale(1.06); }
}

.wheel-wrapper {
  position: relative;
  width: 500rpx;
  height: 500rpx;
}

.wheel-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.wheel-container--spinning {
  opacity: 0.98;
}

.wheel-ring {
  position: absolute;
  top: -20rpx;
  left: -20rpx;
  right: -20rpx;
  bottom: -20rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(44, 24, 16, 0.12);
  box-shadow: inset 0 0 0 8rpx rgba(253, 248, 236, 0.7), inset 0 0 0 10rpx rgba(201, 64, 61, 0.08), 0 10rpx 40rpx rgba(201, 64, 61, 0.22);
  pointer-events: none;
}

.wheel-container__pointer {
  position: absolute;
  top: -36rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 56rpx;
  height: 72rpx;
  z-index: 10;
}

.wheel-container__pointer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 32rpx;
  background: radial-gradient(circle at 35% 35%, var(--terracotta-light) 0%, var(--terracotta) 50%, var(--terracotta-deep) 100%);
  border: 4rpx solid #fdf8ec;
  border-radius: 50%;
}

.wheel-container__pointer::after {
  content: '';
  position: absolute;
  top: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-top: 36rpx solid var(--terracotta-deep);
}

.wheel-container__canvas {
  display: none;
}

.wheel-empty {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(253, 248, 236, 0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx dashed rgba(201, 64, 61, 0.2);
}

.wheel-empty__title {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(44, 24, 16, 0.78);
  letter-spacing: 2rpx;
}

.wheel-empty__sub {
  font-size: 22rpx;
  color: rgba(44, 24, 16, 0.52);
}

.wheel-segment {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.wheel-segment__text {
  position: absolute;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  white-space: nowrap;
  pointer-events: none;
}

.wheel-container__center {
  position: absolute !important;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 50% !important;
  border: none;
  background: radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.4) 0%, transparent 45%), linear-gradient(135deg, var(--terracotta-light) 0%, var(--terracotta) 40%, var(--terracotta-deep) 100%);
  color: #fff;
  display: flex !important;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  z-index: 5;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.wheel-container__center::after {
  border: none;
}

.wheel-container__center-icon {
  font-size: 36rpx;
  line-height: 1;
}

.wheel-container__center-text {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  line-height: 1;
  margin-top: 2rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  flex-shrink: 0;
  padding: 8rpx 0;
}

.actions__btn {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 20rpx 56rpx;
  border: none;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  line-height: 1.4;
  align-items: center;
  gap: 8rpx;
  background: transparent;
  margin: 0;
}

.actions__btn::after {
  border: none;
}

.actions__btn--spin {
  background: linear-gradient(135deg, var(--terracotta-light) 0%, var(--terracotta) 50%, var(--terracotta-deep) 100%);
  color: #fff;
  box-shadow: 0 8rpx 26rpx rgba(201, 64, 61, 0.42);
}

.actions__btn--spin[disabled] {
  opacity: 0.55;
}

.actions__btn--secondary {
  background: rgba(253, 248, 236, 0.6);
  color: var(--ink-soft);
  border: 2rpx solid rgba(44, 24, 16, 0.15);
}

/* 结果区 */
.result {
  text-align: center;
  padding: 8rpx 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.result__card {
  background: linear-gradient(135deg, #fdf8ec 0%, #f8efdb 100%);
  border: 3rpx solid var(--amber);
  border-radius: var(--radius-lg);
  padding: 24rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(201, 64, 61, 0.18), inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  opacity: 0;
  transform: scale(0.85) translateY(20rpx);
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: flex;
  align-items: center;
  gap: 24rpx;
  max-width: 100%;
  position: relative;
}

.result__card--visible {
  opacity: 1;
  transform: scale(1) translateY(0);
}

.result__emoji {
  font-size: 56rpx;
  line-height: 1;
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.5) 0%, transparent 50%), linear-gradient(135deg, rgba(245, 199, 126, 0.35), rgba(201, 64, 61, 0.18));
  border-radius: 50%;
  border: 3rpx solid var(--amber);
}

.result__text {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--ink);
  line-height: 1.3;
  text-align: left;
  flex: 1;
  min-width: 0;
  letter-spacing: 2rpx;
}

.result__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.3s ease 0.15s;
}

.result__actions--visible {
  opacity: 1;
  transform: translateY(0);
}

/* 底部工具栏 */
.toolbar {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 12rpx 12rpx 16rpx;
  flex-shrink: 0;
  z-index: 50;
}

.toolbar__btn {
  width: auto !important;
  min-width: auto !important;
  display: inline-flex !important;
  padding: 14rpx 32rpx;
  border-radius: 100rpx;
  background: rgba(253, 248, 236, 0.85);
  color: var(--ink-soft);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  line-height: 1.4;
  align-items: center;
  gap: 8rpx;
  border: 1rpx solid rgba(44, 24, 16, 0.06);
  box-shadow: 0 4rpx 16rpx rgba(44, 24, 16, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
  margin: 0;
}

.toolbar__btn::after {
  border: none;
}

.toolbar__btn[disabled] {
  opacity: 0.5;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
